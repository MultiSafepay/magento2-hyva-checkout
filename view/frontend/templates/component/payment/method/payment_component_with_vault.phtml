declare(strict_types=1);

/** @var Template $block */
/** @var MultiSafepayPaymentComponentWithVault $magewire */
/** @var Escaper $escaper */

use MultiSafepay\HyvaCheckout\Payment\Method\MultiSafepayPaymentComponentWithVault;
use Magento\Framework\Escaper;
use Magento\Framework\View\Element\Template;

?>
<script>
    (function () {
        const methodCode = '<?= $escaper->escapeJs($magewire->getMethodCode()) ?>';
        const containerSelector = '#multisafepay-<?= $escaper->escapeJs($magewire->getMethodCode()) ?>-component';
        const tokenUrl = '<?= $escaper->escapeJs($block->getUrl('multisafepay_hyva/hyvaCheckout/apiToken')) ?>';
        const componentName = '<?= $escaper->escapeJs($block->getNameInLayout()) ?>';

        const TOKEN_MAX_AGE_MS = 8 * 60 * 1000;

        let paymentComponent = null;
        let tokenFetchedAt = 0;

        async function fetchFreshApiToken() {
            const res = await fetch(tokenUrl, {
                method: 'GET',
                credentials: 'same-origin',
                headers: { 'Accept': 'application/json' }
            });

            const data = await res.json().catch(() => ({}));

            if (!res.ok || !data || !data.success || !data.apiToken) {
                throw new Error((data && data.message) ? data.message : 'Failed to refresh API token');
            }

            return data.apiToken;
        }

        function initPaymentComponent(apiToken, paymentComponentDataBase) {
            const paymentComponentData = Object.assign({}, paymentComponentDataBase, { apiToken });

            paymentComponent = new MultiSafepay(paymentComponentData);

            paymentComponent.init('payment', {
                container: containerSelector,
                gateway: '<?= $escaper->escapeJs($magewire->getGatewayCode()) ?>',
                onError: (state) => {
                    const paymentComponentDataJson = JSON.stringify(paymentComponentData, null, 2);
                    const error = 'Payment Component error: ' + JSON.stringify(state, null, 2);

                    <?php if ($magewire->isDebugModeEnabled()) { ?>
                    console.log(error);
                    <?php } ?>

                    Magewire.find(componentName).logPaymentComponentError(error, paymentComponentDataJson);
                }
            });
        }

        window.addEventListener('checkout:payment:method-activate', async (event) => {
            if (event.detail.method !== methodCode || !document.querySelector(containerSelector)) {
                return;
            }

            <?php if ($magewire->isVaultEnabled()) { ?>

            const componentDiv = document.getElementById('multisafepay-<?= $escaper->escapeJs($magewire->getMethodCode()) ?>-component');

            if (componentDiv && !document.getElementById('multisafepay_vault_checkbox')) {
                const vaultLabel = '<?= $escaper->escapeJs(__('Save for later use')) ?>';

                componentDiv.insertAdjacentHTML(
                    "afterend",
                    '<label><input type="checkbox" id="multisafepay_vault_checkbox" name="multisafepay_vault_checkbox" /> ' + vaultLabel + '</label>'
                );
            }

            const vaultCheckbox = document.getElementById('multisafepay_vault_checkbox');

            if (vaultCheckbox) {
                vaultCheckbox.addEventListener('change', (checkboxEvent) => {
                    Magewire.find(componentName).updateVaultTokenEnabler(checkboxEvent.target.checked);
                });
            }
            <?php } ?>

            <?php if ($magewire->isPaymentComponentEnabled()) { ?>
            const orderData = {
                currency: '<?= $escaper->escapeJs($magewire->getCurrency()) ?>',
                amount: '<?= $escaper->escapeJs($magewire->getAmount()) ?>',
                template: { settings: { embed_mode: true }, merge: true },
                customer: {
                    locale: '<?= $escaper->escapeJs($magewire->getLocale()) ?>',
                    country: '<?= $escaper->escapeJs($magewire->getCountry()) ?>'
                }
            };

            let recurringData;
            <?php if ($magewire->getTokens()) { ?>
            recurringData = { model: 'cardOnFile', tokens: <?= $magewire->getTokens() ?> };
            <?php } ?>

            const paymentComponentDataBase = {
                env: '<?= $escaper->escapeJs($magewire->getEnvironment()) ?>',
                order: orderData
            };

            if (recurringData) {
                paymentComponentDataBase.recurring = recurringData;
            }

            try {
                const apiToken = await fetchFreshApiToken();
                initPaymentComponent(apiToken, paymentComponentDataBase);
                tokenFetchedAt = Date.now();
            } catch (e) {
                <?php if ($magewire->isDebugModeEnabled()) { ?>
                console.error('MultiSafepay token refresh failed on activation:', e);
                <?php } ?>
                return;
            }

            hyvaCheckout.validation.register(
                methodCode,
                async () => {
                    if (!paymentComponent) {
                        return false;
                    }

                    if (tokenFetchedAt && (Date.now() - tokenFetchedAt) > TOKEN_MAX_AGE_MS) {
                        Magewire.find(componentName).dispatchErrorMessage(
                            'Your payment session expired. Please re-select the payment method and try again.'
                        );
                        return false;
                    }

                    const paymentData = await paymentComponent.getPaymentData();

                    if (paymentComponent.hasErrors()) {
                        return false;
                    }

                    Magewire.find(componentName).setPaymentComponentData({
                        payload: paymentData.payload,
                        tokenize: paymentData.tokenize ?? false
                    });

                    return new Promise(resolve => setTimeout(() => resolve(true), 1000));
                },
                document.querySelector(containerSelector),
                'payment'
            );
            <?php } ?>
        });
    })();
</script>
<?php isset($hyvaCsp) && $hyvaCsp->registerInlineScript() ?>
